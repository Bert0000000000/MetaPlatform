# ─────────────────────────────────────────────────────────────
# metaplatform-app-service environment variables (example)
# Sprint 0: 提供模板；正式值由部署环境注入
# ─────────────────────────────────────────────────────────────

# HTTP 端口（默认 3002）
PORT=3002

# JWT 校验密钥 —— 必须与 metaplatform-api 颁发 JWT 时使用的密钥一致
# Sprint 0 stub：不真正校验签名，仅占位
JWT_SECRET=replace-me-with-shared-secret

# 外部服务地址（后续 Sprint 接 clients 时使用）
ONTOLOGY_ENGINE_URL=http://localhost:8090
PAGE_GENERATOR_URL=http://localhost:8083
METAPLATFORM_API_URL=http://localhost:3001

# 日志级别
LOG_LEVEL=info

# 节点环境
NODE_ENV=development
