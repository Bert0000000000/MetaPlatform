# MetaPlatform E2E - Git Ignore
# ==============================

# Environment overrides (local secrets)
.env.local
.env.*.local

# Test output artifacts
e2e/results/
e2e/logs/
*.log
*.tmp

# Docker volumes
data/

# Editor / IDE
.vscode/
.idea/
*.swp
*.swo
*~

# OS artifacts
.DS_Store
Thumbs.db

# Node / Python (if used for helper scripts)
node_modules/
__pycache__/
*.pyc
