# ============================================================================
# MetaPlatform E2E Integration Test - Unified Port Mapping
# ============================================================================
# This file defines the canonical port allocation for all MetaPlatform services
# in the local E2E test environment. Every service and script should read from
# here to avoid port conflicts.
# ============================================================================

# --- Infrastructure: PostgreSQL (single instance, multiple databases) ---
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=meta
POSTGRES_PASSWORD=metaplatform
POSTGRES_DB=metaplatform

# Databases created by init-multi-db.sh
DB_PLATFORM_BASE=platform_base
DB_AI_SUBSTRATE=ai_substrate
DB_ONTOLOGY_META=ontology_meta
DB_DATA_STACK=data_stack
DB_PAGE_GENERATOR=page_generator
DB_DIALOGUE=dialogue
DB_CAPABILITY=capability
DB_PROCESS_ENGINE=process_engine
DB_RAG_MDM=rag_mdm

# --- Infrastructure: Redis ---
REDIS_HOST=localhost
REDIS_PORT=6379

# --- Infrastructure: Apache Kafka ---
KAFKA_BROKER=localhost:9092

# --- Infrastructure: Neo4j ---
NEO4J_URI=bolt://localhost:7687
NEO4J_HTTP_PORT=7474
NEO4J_USER=neo4j
NEO4J_PASSWORD=metaplatform

# --- Infrastructure: MinIO (S3-compatible object storage) ---
MINIO_API_PORT=9000
MINIO_CONSOLE_PORT=9001
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin

# --- Application Services ---
# L2-2 Ontology Engine (Java 21 + Spring Boot)
ONTOLOGY_ENGINE_PORT=8080

# L2-3 Data Stack (Go 1.22 + Gin)
DATA_STACK_PORT=8081

# L2-1 Platform Base - Multi-tenant / RBAC / Audit (Java 21 + Spring Boot)
PLATFORM_BASE_PORT=8082

# L2-4 AI Substrate - LLM Gateway / Embedding / Context (Java 21 + Spring Boot)
AI_SUBSTRATE_PORT=8083

# L1-3 Page/Form Generator (Java 21 + Spring Boot)
PAGE_GENERATOR_PORT=8084

# L1-4 Dialogue Layer (Java 21 + Spring Boot)
DIALOGUE_PORT=8085

# L1-5 Capability Library (Java 21 + Spring Boot)
CAPABILITY_LIBRARY_PORT=8086

# L1-6 Process Automation Engine (Java 21 + Spring Boot)
PROCESS_ENGINE_PORT=8087

# L1-7 RAG / Knowledge / MDM (Java 21 + Spring Boot)
RAG_MDM_PORT=8090

# --- Test Configuration ---
# Maximum seconds to wait for a service to become healthy
HEALTH_TIMEOUT=120
# Seconds between health check retries
HEALTH_INTERVAL=3
# Tenant ID used in E2E tests
E2E_TENANT_ID=00000000-0000-0000-0000-000000000001
E2E_TENANT_NAME=e2e-test-tenant
