# ════════════════════════════════════════════════════════════
# MetaPlatform API — Environment Variables
# ════════════════════════════════════════════════════════════

# ── Database ────────────────────────────────────────────
# PostgreSQL (production) — leave unset to fall back to SQLite
DATABASE_URL=postgres://meta:meta@localhost:5432/metaplatform

# ── Redis (cache layer) ─────────────────────────────────
REDIS_URL=redis://localhost:6379

# ── JWT / Auth ──────────────────────────────────────────
# IMPORTANT: override this in production!
JWT_SECRET=metaplatform-prod-secret-change-in-production

# ── LLM (OpenAI-compatible) ─────────────────────────────
LLM_BASE_URL=https://api.openai.com/v1
LLM_API_KEY=
LLM_MODEL=gpt-4o-mini

# ── Phase 2: Storage Layer Backends ─────────────────────

# Neo4j — Graph database (ontology engine)
NEO4J_URL=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=metaplatform2026
NEO4J_DATABASE=neo4j

# Elasticsearch — Full-text search
ELASTICSEARCH_URL=http://localhost:9200
ELASTICSEARCH_INDEX=metaplatform

# Milvus — Vector search (optional; falls back to in-process cosine if unreachable)
MILVUS_URL=
MILVUS_COLLECTION=metaplatform_vectors
EMBEDDING_DIM=384

# MinIO — S3-compatible object storage
MINIO_ENDPOINT=localhost
MINIO_PORT=9000
MINIO_ACCESS_KEY=metaplatform
MINIO_SECRET_KEY=metaplatform_secret_2026
MINIO_BUCKET=metaplatform
MINIO_USE_SSL=false

# Kafka — Event streaming
KAFKA_BROKERS=localhost:9092
KAFKA_CLIENT_ID=metaplatform-api
KAFKA_GROUP_ID=metaplatform-api-consumers

# ── Server ──────────────────────────────────────────────
NODE_ENV=development
PORT=3001
