# Windows compatibility: pnpm's default global store fails with EBUSY/EPERM
# when creating the project-registration symlink on this Windows environment.
# Using a project-local store mitigates the permission/symlink issue.
store-dir=.pnpm-store

# Disable pnpm 11 dep verification before run (esbuild build script is non-critical)
verify-deps-before-run=false

# Auto-confirm module purge in CI/Docker (no TTY)
confirmModulesPurge=false

# Fallback for Windows environments where pnpm symlinks are blocked:
# In metaplatform-frontend/apps/ontstudio you can run
#   npm install --no-workspaces --legacy-peer-deps
# to install this sub-app independently. For full Vite production builds,
# prefer WSL2 / Linux / CI because of known Windows NTFS metadata issues
# with nested node_modules directories (e.g. vite/node_modules).
