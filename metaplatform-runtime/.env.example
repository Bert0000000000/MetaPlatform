# MetaPlatform Runtime — local dev environment template.
# Copy to .env, fill in real values, then `npm start`.
#
# In production these come from:
#   - PORT, HOST, RUNTIME_DB_PATH, RUNTIME_ADMIN_TOKEN  →  K8s env
#   - APP_ID, APP_SLUG                                  →  metadata.labels
#   - POD_NAME, POD_NAMESPACE                            →  fieldRef

# HTTP listener
PORT=3000
HOST=0.0.0.0

# Path to the published sqlite snapshot (RO mount in K8s, see
# runtime-deployment.yaml). In dev, point at any published app.db
# you've exported.
RUNTIME_DB_PATH=./dev-data/app.db

# Admin token required to hit /health and view detailed runtime
# metadata. Generate with `openssl rand -hex 32`. If unset, /health
# is hidden entirely (always 404).
RUNTIME_ADMIN_TOKEN=

# Staging tmpfs size (bytes) — only relevant when RUNTIME_DB_PATH
# needs to be copied off RO mount. Default 64 MiB.
RUNTIME_STAGING_BYTES=67108864
