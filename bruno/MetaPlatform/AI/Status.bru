meta {
  name: AI Status
  type: http
  seq: 1
}

get {
  url: {{baseUrl}}/api/ai/status
  body: none
  auth: bearer
}

auth:bearer {
  token: {{token}}
}

docs {
  Aggregated status of all AI subsystems:
  - embeddings provider + model + dimension
  - llm provider + default model
  - ocr languages loaded
  - agent tools count
}

tests {
  test("embeddings configured", function() {
    expect(res.body.data.embeddings).to.have.property('dimension');
  });
  test("llm configured", function() {
    expect(res.body.data.llm).to.have.property('provider');
  });
  test("ocr configured", function() {
    expect(res.body.data.ocr).to.have.property('defaultLangs');
  });
}