meta {
  name: Scheduler status
  type: http
  seq: 1
}

get {
  url: {{baseUrl}}/api/scheduler/status
  body: none
  auth: bearer
}

auth:bearer {
  token: {{token}}
}

tests {
  test("running", function() {
    expect(res.body.data.running).to.equal(true);
  });
  test("has jobs", function() {
    expect(res.body.data.jobCount).to.be.at.least(2);
  });
}