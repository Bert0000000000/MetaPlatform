<!DOCTYPE html>
<html lang="en" class="light">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Untitled</title>
    <style id="theme-vars">
/* ============================================================
 * MetaPlatform Design — Draft (精简版)
 * Compact, minimal, small-radius enterprise style
 * ============================================================ */

/* ---- Brand Prefix: mp ---- */

:root {
  /* Primary */
  --color-primary: #3b82f6;
  --color-primary-hover: #2563eb;
  --color-primary-light: #eff6ff;

  /* Neutral — minimal set */
  --color-bg: #ffffff;
  --color-bg-secondary: #f8fafc;
  --color-surface: #ffffff;
  --color-surface-hover: #f8fafc;

  /* Sidebar */
  --color-sidebar-bg: #0f172a;
  --color-sidebar-text: #94a3b8;
  --color-sidebar-text-hover: #cbd5e1;
  --color-sidebar-active-bg: rgba(59, 130, 246, 0.15);
  --color-sidebar-active-text: #60a5fa;
  --color-sidebar-border: rgba(148, 163, 184, 0.1);

  /* Text — 3 levels only */
  --color-text-primary: #0f172a;
  --color-text-secondary: #64748b;
  --color-text-inverse: #ffffff;

  /* Border — 1 token only */
  --color-border: #e2e8f0;

  /* State — 3 semantic colors, bg derived */
  --state-success: #22c55e;
  --state-success-bg: #f0fdf4;
  --state-warning: #f59e0b;
  --state-warning-bg: #fffbeb;
  --state-error: #ef4444;
  --state-error-bg: #fef2f2;

  /* ---- Typography ---- */
  --font-sans: "Inter", -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, "Helvetica Neue", Arial, "Noto Sans SC", sans-serif;
  --font-mono: "SFMono-Regular", Consolas, "Liberation Mono", Menlo, monospace;

  --font-size-xs: 11px;
  --font-size-sm: 12px;
  --font-size-base: 13px;
  --font-size-lg: 14px;
  --font-size-xl: 18px;
  --font-size-2xl: 22px;

  --font-weight-normal: 400;
  --font-weight-medium: 500;
  --font-weight-semibold: 600;

  --line-height-normal: 1.5;

  /* ---- Spacing — compact scale ---- */
  --spacing-xs: 2px;
  --spacing-sm: 4px;
  --spacing-md: 8px;
  --spacing-lg: 12px;
  --spacing-xl: 16px;
  --spacing-2xl: 24px;

  /* ---- Radius — SMALL ---- */
  --radius-sm: 3px;
  --radius-md: 4px;
  --radius-lg: 6px;
  --radius-full: 9999px;

  /* ---- Shadows — minimal ---- */
  --shadow-sm: 0 1px 2px rgba(0, 0, 0, 0.04);
  --shadow-float: 0 8px 24px rgba(0, 0, 0, 0.1);

  /* ---- Layout ---- */
  --sidebar-width: 220px;
}

    </style>
    <script src="https://cdn.jsdelivr.net/npm/@tailwindcss/browser@4.3.1/dist/index.global.js"></script>
    <script src="https://unpkg.com/lucide@1.8.0/dist/umd/lucide.min.js"></script>
    <style type="text/tailwindcss">
  @theme inline {
    --color-primary: var(--color-primary);
    --color-border: var(--color-border);
  }
  @layer base {
    body { background: var(--color-surface); color: var(--color-text-primary); }
    td, th { @apply break-words; word-break: break-all; word-break: auto-phrase; }
    th { @apply whitespace-nowrap; }
  }
    </style>
    <style>
      .no-scrollbar::-webkit-scrollbar { display: none; }
      .no-scrollbar { -ms-overflow-style: none; scrollbar-width: none; }
      [data-icon] {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        -webkit-mask-size: contain;
        mask-size: contain;
        -webkit-mask-repeat: no-repeat;
        mask-repeat: no-repeat;
        -webkit-mask-position: center;
        mask-position: center;
        background-color: currentColor;
      }
    </style>
</head>
<body class="font-sans antialiased" style="font-family: var(--font-sans); font-size: var(--font-size-base);">

<div class="flex min-h-screen">

  <!-- Sidebar -->
  <aside class="w-[220px] flex flex-col flex-shrink-0 fixed inset-y-0 left-0 z-10" style="background: var(--color-sidebar-bg);">

    <!-- Brand -->
    <div class="flex items-center gap-2 px-3 py-3" style="border-bottom: 1px solid var(--color-sidebar-border);">
      <span class="w-8 h-8 text-white flex items-center justify-center font-bold text-xs" style="background: var(--color-primary); border-radius: var(--radius-md);">M</span>
      <span class="text-sm font-semibold" style="color: #f1f5f9;">MetaPlatform</span>
    </div>

    <!-- Nav -->
    <nav class="flex flex-col px-2 py-3 gap-0.5 flex-1">

      <!-- 1. 页面配置 (active) -->
      <a data-nav-key="dashboard" data-active="true" class="flex items-center gap-0.5 px-2.5 py-1.5 cursor-pointer" style="background: var(--color-sidebar-active-bg); color: var(--color-sidebar-active-text); border-radius: var(--radius-md); font-size: var(--font-size-sm);">
        <svg class="w-3.5 h-3.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <rect x="3" y="3" width="7" height="7" rx="1"/>
          <rect x="14" y="3" width="7" height="7" rx="1"/>
          <rect x="3" y="14" width="7" height="7" rx="1"/>
          <rect x="14" y="14" width="7" height="7" rx="1"/>
        </svg>
        <span>页面配置</span>
      </a>

      <!-- 2. ObjectType -->
      <a data-nav-key="objecttype" class="flex items-center gap-0.5 px-2.5 py-1.5 cursor-pointer transition-colors" style="color: var(--color-sidebar-text); border-radius: var(--radius-md); font-size: var(--font-size-sm);" onmouseover="this.style.background='rgba(255,255,255,0.05)';this.style.color='var(--color-sidebar-text-hover)'" onmouseout="this.style.background='transparent';this.style.color='var(--color-sidebar-text)'">
        <svg class="w-3.5 h-3.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <path d="M21 16V8a2 2 0 0 0-1-1.73l-7-4a2 2 0 0 0-2 0l-7 4A2 2 0 0 0 3 8v8a2 2 0 0 0 1 1.73l7 4a2 2 0 0 0 2 0l7-4A2 2 0 0 0 21 16z"/>
          <polyline points="3.27 6.96 12 12.01 20.73 6.96"/>
          <line x1="12" y1="22.08" x2="12" y2="12"/>
        </svg>
        <span>ObjectType</span>
      </a>

      <!-- 3. 建模特工场 -->
      <a data-nav-key="modeling-workshop" class="flex items-center gap-0.5 px-2.5 py-1.5 cursor-pointer transition-colors" style="color: var(--color-sidebar-text); border-radius: var(--radius-md); font-size: var(--font-size-sm);" onmouseover="this.style.background='rgba(255,255,255,0.05)';this.style.color='var(--color-sidebar-text-hover)'" onmouseout="this.style.background='transparent';this.style.color='var(--color-sidebar-text)'">
        <svg class="w-3.5 h-3.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <path d="M14.7 6.3a1 1 0 0 0 0 1.4l1.6 1.6a1 1 0 0 0 1.4 0l3.77-3.77a6 6 0 0 1-7.94 7.94l-6.91 6.91a2.12 2.12 0 0 1-3-3l6.91-6.91a6 6 0 0 1 7.94-7.94l-3.76 3.76z"/>
        </svg>
        <span>建模特工场</span>
      </a>

      <!-- 4. 设计器 -->
      <a data-nav-key="designer" class="flex items-center gap-0.5 px-2.5 py-1.5 cursor-pointer transition-colors" style="color: var(--color-sidebar-text); border-radius: var(--radius-md); font-size: var(--font-size-sm);" onmouseover="this.style.background='rgba(255,255,255,0.05)';this.style.color='var(--color-sidebar-text-hover)'" onmouseout="this.style.background='transparent';this.style.color='var(--color-sidebar-text)'">
        <svg class="w-3.5 h-3.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <path d="M12 19l7-7 3 3-7 7-3-3z"/>
          <path d="M18 13l-1.5-7.5L2 2l3.5 14.5L13 18l5-5z"/>
          <path d="M2 2l7.586 7.586"/>
          <circle cx="11" cy="11" r="2"/>
        </svg>
        <span>设计器</span>
      </a>

      <!-- 5. 流程设计器 -->
      <a data-nav-key="flow-designer" class="flex items-center gap-0.5 px-2.5 py-1.5 cursor-pointer transition-colors" style="color: var(--color-sidebar-text); border-radius: var(--radius-md); font-size: var(--font-size-sm);" onmouseover="this.style.background='rgba(255,255,255,0.05)';this.style.color='var(--color-sidebar-text-hover)'" onmouseout="this.style.background='transparent';this.style.color='var(--color-sidebar-text)'">
        <svg class="w-3.5 h-3.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <line x1="6" y1="3" x2="6" y2="15"/>
          <circle cx="18" cy="6" r="3"/>
          <circle cx="6" cy="18" r="3"/>
          <path d="M18 9a9 9 0 0 1-9 9"/>
        </svg>
        <span>流程设计器</span>
      </a>

      <!-- 6. AI 对话 -->
      <a data-nav-key="dialogue" data-dom-id="nav-dialogue" class="flex items-center gap-0.5 px-2.5 py-1.5 cursor-pointer transition-colors" style="color: var(--color-sidebar-text); border-radius: var(--radius-md); font-size: var(--font-size-sm);" onmouseover="this.style.background='rgba(255,255,255,0.05)';this.style.color='var(--color-sidebar-text-hover)'" onmouseout="this.style.background='transparent';this.style.color='var(--color-sidebar-text)'">
        <svg class="w-3.5 h-3.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/>
        </svg>
        <span>AI 对话</span>
      </a>

      <!-- 7. 能力中心 -->
      <a data-nav-key="capability" data-dom-id="nav-capability" class="flex items-center gap-0.5 px-2.5 py-1.5 cursor-pointer transition-colors" style="color: var(--color-sidebar-text); border-radius: var(--radius-md); font-size: var(--font-size-sm);" onmouseover="this.style.background='rgba(255,255,255,0.05)';this.style.color='var(--color-sidebar-text-hover)'" onmouseout="this.style.background='transparent';this.style.color='var(--color-sidebar-text)'">
        <svg class="w-3.5 h-3.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <polygon points="13 2 3 14 12 14 11 22 21 10 12 10 13 2"/>
        </svg>
        <span>能力中心</span>
      </a>

      <!-- 8. 集成中心 -->
      <a data-nav-key="integration" data-dom-id="nav-integration" class="flex items-center gap-0.5 px-2.5 py-1.5 cursor-pointer transition-colors" style="color: var(--color-sidebar-text); border-radius: var(--radius-md); font-size: var(--font-size-sm);" onmouseover="this.style.background='rgba(255,255,255,0.05)';this.style.color='var(--color-sidebar-text-hover)'" onmouseout="this.style.background='transparent';this.style.color='var(--color-sidebar-text)'">
        <svg class="w-3.5 h-3.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"/>
          <polyline points="15 3 21 3 21 9"/>
          <line x1="10" y1="14" x2="21" y2="3"/>
        </svg>
        <span>集成中心</span>
      </a>

    </nav>

    <!-- Bottom user area -->
    <div class="px-3 py-3 flex items-center gap-2" style="border-top: 1px solid var(--color-sidebar-border);">
      <div class="w-6 h-6 flex items-center justify-center" style="background: #334155; color: #94a3b8; border-radius: var(--radius-full); font-size: 10px; font-weight: 500;">A</div>
      <div class="flex-1 min-w-0">
        <div class="truncate" style="color: var(--color-sidebar-text-hover); font-size: var(--font-size-sm);">Admin</div>
        <div class="truncate" style="color: #64748b; font-size: var(--font-size-xs);">admin@metaplatform.io</div>
      </div>
    </div>

  </aside>

  <!-- Main content -->
  <main class="flex-1 ml-[220px] p-5 min-w-0" style="background: var(--color-bg);">

    <!-- Page Header -->
    <div class="mb-3">
      <h1 class="font-semibold" style="font-size: var(--font-size-xl); color: var(--color-text-primary); letter-spacing: -0.02em; line-height: 1.25; text-wrap: balance; word-break: keep-all;">页面配置管理</h1>
      <p class="mt-1" style="font-size: var(--font-size-sm); color: var(--color-text-secondary);">管理已生成的页面配置，或从 ObjectType 一键生成新页面。</p>
    </div>

    <!-- Stats Row -->
    <div class="flex gap-3 mb-3">
      <div class="flex-1 px-3 py-3" style="border: 1px solid var(--color-border); border-radius: var(--radius-lg);">
        <div class="font-semibold" style="font-size: var(--font-size-xl); color: var(--color-text-primary); font-variant-numeric: tabular-nums; line-height: 1.25;">12</div>
        <div class="mt-0.5" style="font-size: var(--font-size-xs); color: var(--color-text-secondary);">总页面数</div>
      </div>
      <div class="flex-1 px-3 py-3" style="border: 1px solid var(--color-border); border-radius: var(--radius-lg);">
        <div class="font-semibold" style="font-size: var(--font-size-xl); color: var(--color-text-primary); font-variant-numeric: tabular-nums; line-height: 1.25;">4</div>
        <div class="mt-0.5" style="font-size: var(--font-size-xs); color: var(--color-text-secondary);">本月新增</div>
      </div>
      <div class="flex-1 px-3 py-3" style="border: 1px solid var(--color-border); border-radius: var(--radius-lg);">
        <div class="font-semibold" style="font-size: var(--font-size-xl); color: var(--color-text-primary); font-variant-numeric: tabular-nums; line-height: 1.25;">8</div>
        <div class="mt-0.5" style="font-size: var(--font-size-xs); color: var(--color-text-secondary);">活跃页面</div>
      </div>
    </div>

    <!-- Quick Generate Section -->
    <div class="mb-3">
      <h2 class="font-medium mb-3" style="font-size: var(--font-size-lg); color: var(--color-text-primary);">快速生成页面</h2>
      <div class="grid grid-cols-4 gap-3">

        <!-- Card: 客户管理 -->
        <div class="p-3 transition-colors" style="border: 1px solid var(--color-border); border-radius: var(--radius-lg); background: var(--color-surface); transition-duration: 150ms; transition-timing-function: cubic-bezier(0.2, 0.8, 0.2, 1);" onmouseover="this.style.borderColor='#93c5fd'" onmouseout="this.style.borderColor='var(--color-border)'">
          <div class="font-medium" style="font-size: var(--font-size-base); color: var(--color-text-primary);">客户管理</div>
          <div class="mt-0.5" style="font-size: var(--font-size-xs); color: var(--color-text-secondary); font-family: var(--font-mono);">customer</div>
          <p class="mt-1.5" style="font-size: var(--font-size-xs); color: var(--color-text-secondary); line-height: 1.5;">核心业务对象，包含客户基本信息</p>
          <div class="mt-3">
            <button class="inline-flex items-center justify-center text-white whitespace-nowrap transition-colors" style="font-size: var(--font-size-xs); font-weight: 500; padding: 4px 10px; border-radius: var(--radius-md); background: var(--color-primary); transition-property: background-color; transition-duration: 150ms;" onmouseover="this.style.background='var(--color-primary-hover)'" onmouseout="this.style.background='var(--color-primary)'" onfocus="this.style.outline='2px solid var(--color-primary)';this.style.outlineOffset='2px'" onblur="this.style.outline='none'">生成页面</button>
          </div>
        </div>

        <!-- Card: 工单系统 -->
        <div class="p-3 transition-colors" style="border: 1px solid var(--color-border); border-radius: var(--radius-lg); background: var(--color-surface); transition-duration: 150ms; transition-timing-function: cubic-bezier(0.2, 0.8, 0.2, 1);" onmouseover="this.style.borderColor='#93c5fd'" onmouseout="this.style.borderColor='var(--color-border)'">
          <div class="font-medium" style="font-size: var(--font-size-base); color: var(--color-text-primary);">工单系统</div>
          <div class="mt-0.5" style="font-size: var(--font-size-xs); color: var(--color-text-secondary); font-family: var(--font-mono);">ticket</div>
          <p class="mt-1.5" style="font-size: var(--font-size-xs); color: var(--color-text-secondary); line-height: 1.5;">技术支持工单生命周期管理</p>
          <div class="mt-3">
            <button class="inline-flex items-center justify-center text-white whitespace-nowrap transition-colors" style="font-size: var(--font-size-xs); font-weight: 500; padding: 4px 10px; border-radius: var(--radius-md); background: var(--color-primary); transition-property: background-color; transition-duration: 150ms;" onmouseover="this.style.background='var(--color-primary-hover)'" onmouseout="this.style.background='var(--color-primary)'" onfocus="this.style.outline='2px solid var(--color-primary)';this.style.outlineOffset='2px'" onblur="this.style.outline='none'">生成页面</button>
          </div>
        </div>

        <!-- Card: 产品目录 -->
        <div class="p-3 transition-colors" style="border: 1px solid var(--color-border); border-radius: var(--radius-lg); background: var(--color-surface); transition-duration: 150ms; transition-timing-function: cubic-bezier(0.2, 0.8, 0.2, 1);" onmouseover="this.style.borderColor='#93c5fd'" onmouseout="this.style.borderColor='var(--color-border)'">
          <div class="font-medium" style="font-size: var(--font-size-base); color: var(--color-text-primary);">产品目录</div>
          <div class="mt-0.5" style="font-size: var(--font-size-xs); color: var(--color-text-secondary); font-family: var(--font-mono);">product</div>
          <p class="mt-1.5" style="font-size: var(--font-size-xs); color: var(--color-text-secondary); line-height: 1.5;">产品信息与分类管理</p>
          <div class="mt-3">
            <button class="inline-flex items-center justify-center text-white whitespace-nowrap transition-colors" style="font-size: var(--font-size-xs); font-weight: 500; padding: 4px 10px; border-radius: var(--radius-md); background: var(--color-primary); transition-property: background-color; transition-duration: 150ms;" onmouseover="this.style.background='var(--color-primary-hover)'" onmouseout="this.style.background='var(--color-primary)'" onfocus="this.style.outline='2px solid var(--color-primary)';this.style.outlineOffset='2px'" onblur="this.style.outline='none'">生成页面</button>
          </div>
        </div>

        <!-- Card: 销售线索 -->
        <div class="p-3 transition-colors" style="border: 1px solid var(--color-border); border-radius: var(--radius-lg); background: var(--color-surface); transition-duration: 150ms; transition-timing-function: cubic-bezier(0.2, 0.8, 0.2, 1);" onmouseover="this.style.borderColor='#93c5fd'" onmouseout="this.style.borderColor='var(--color-border)'">
          <div class="font-medium" style="font-size: var(--font-size-base); color: var(--color-text-primary);">销售线索</div>
          <div class="mt-0.5" style="font-size: var(--font-size-xs); color: var(--color-text-secondary); font-family: var(--font-mono);">lead</div>
          <p class="mt-1.5" style="font-size: var(--font-size-xs); color: var(--color-text-secondary); line-height: 1.5;">销售线索跟踪与转化</p>
          <div class="mt-3">
            <button class="inline-flex items-center justify-center text-white whitespace-nowrap transition-colors" style="font-size: var(--font-size-xs); font-weight: 500; padding: 4px 10px; border-radius: var(--radius-md); background: var(--color-primary); transition-property: background-color; transition-duration: 150ms;" onmouseover="this.style.background='var(--color-primary-hover)'" onmouseout="this.style.background='var(--color-primary)'" onfocus="this.style.outline='2px solid var(--color-primary)';this.style.outlineOffset='2px'" onblur="this.style.outline='none'">生成页面</button>
          </div>
        </div>

      </div>
    </div>

    <!-- Generated Pages Table -->
    <div>
      <h2 class="font-medium mb-3" style="font-size: var(--font-size-lg); color: var(--color-text-primary);">已生成页面 <span class="font-normal" style="font-size: var(--font-size-sm); color: var(--color-text-secondary);">(4)</span></h2>
      <div style="border: 1px solid var(--color-border); border-radius: var(--radius-lg); overflow: hidden;">
        <table class="w-full" style="font-size: var(--font-size-sm);">
          <thead>
            <tr style="background: var(--color-bg-secondary);">
              <th class="text-left px-3 py-1.5 font-medium whitespace-nowrap" style="font-size: var(--font-size-xs); color: var(--color-text-secondary);">显示名称</th>
              <th class="text-left px-3 py-1.5 font-medium whitespace-nowrap" style="font-size: var(--font-size-xs); color: var(--color-text-secondary);">名称</th>
              <th class="text-left px-3 py-1.5 font-medium whitespace-nowrap" style="font-size: var(--font-size-xs); color: var(--color-text-secondary);">页面类型</th>
              <th class="text-left px-3 py-1.5 font-medium whitespace-nowrap" style="font-size: var(--font-size-xs); color: var(--color-text-secondary);">创建时间</th>
              <th class="text-right px-3 py-1.5 font-medium whitespace-nowrap" style="font-size: var(--font-size-xs); color: var(--color-text-secondary);">操作</th>
            </tr>
          </thead>
          <tbody>
            <!-- Row 1 -->
            <tr style="border-top: 1px solid var(--color-border);">
              <td class="px-3 py-1.5 whitespace-nowrap" style="font-size: var(--font-size-sm); color: var(--color-text-primary);">客户列表页</td>
