# MetaPlatform 环境变量配置
# 复制此文件为 .env 并根据需要修改

# === 数据库 ===
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=ontology_meta
POSTGRES_USER=meta
POSTGRES_PASSWORD=metaplatform

# === Redis ===
REDIS_HOST=localhost
REDIS_PORT=6379

# === Kafka ===
KAFKA_BROKER=localhost:9092

# === AI/LLM 配置 ===
AI_LLM_BASE_URL=https://api.openai.com/v1
AI_LLM_API_KEY=sk-your-api-key-here
AI_LLM_MODEL=gpt-4o-mini
AI_LLM_MAX_TOKENS=2048
AI_LLM_TIMEOUT=30000

# === 服务端口 ===
ONTOLOGY_ENGINE_PORT=8090
PAGE_GENERATOR_PORT=8083
FRONTEND_PORT=5173

# === 多租户 ===
DEFAULT_TENANT_ID=00000000-0000-0000-0000-000000000001

# === 可观测性 ===
PROMETHEUS_PORT=9090
GRAFANA_PORT=3001
GRAFANA_ADMIN_PASSWORD=metaplatform
