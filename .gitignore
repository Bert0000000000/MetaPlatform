# Build outputs
**/target/
**/*.class
**/*.jar
**/*.war
**/dist/

# Node
**/node_modules/
**/package-lock.json
**/.vite/
**/*.tsbuildinfo

# Backend runtime
metaplatform-api/data/
metaplatform-api/backups/

# Published-app snapshot files (one sqlite per published app; created
# at publish time and re-populated on each re-publish. Never commit
# them — they're test output and runtime artifacts).
data/published/

# IDE
.idea/
*.iml
.vscode/
*.swp
*.swo

# OS
.DS_Store
Thumbs.db

# Logs
*.log
logs/
# Trae IDE AI agent generated logs (cache/debug output)
.*.log

# Local Node runtime (portable binaries)
tools/node-v22/

# Local Maven runtime (portable binaries)
tools/maven/

# RuoYi-Vue-Pro source code (large, cloned on demand)
deploy/ruoyi-build/ruoyi-vue-pro/

# Verification screenshots / logs
verify-*.png
docs/artifacts/verification/screenshots/
docs/artifacts/verification/logs/
*.err
*.out

# Maven wrapper
!.mvn/wrapper/maven-wrapper.jar

# Python cache
__pycache__/
*.pyc
*.pyo
*.egg-info/
.eggs/

# SQLite local dev databases
*.db

# Pytest cache
.pytest_cache/

# Build artifacts
BOOT-INF/
META-INF/

# Vite generated config artifacts
*.vite.config.d.ts

# Local .env files
.env

# Temporary scripts and JSON outputs
docs/006-TMP/*.json
docs/006-TMP/*.txt
docs/006-TMP/jwt.txt
# Temporary screenshots and images produced during verification
docs/006-TMP/*.png
docs/006-TMP/*.jpg
docs/006-TMP/*.jpeg
docs/006-TMP/*.gif
docs/006-TMP/*.webp
docs/006-TMP/backend-logs/
docs/006-TMP/frontend-logs/
# Verification screenshots generated in app directories
**/multimodal-*.png
**/tmp-*.png
**/tmp-*.html
**/tmp-*.json
**/tmp-*.py
# Design drafts
metaplatform-design-draft/
